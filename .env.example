# Aplicacion
TICA_APP_NAME="Dokka TICA Scraper"
TICA_APP_ENV="development"
TICA_API_PREFIX="/v1"
TICA_LOG_LEVEL="INFO"

# Portal TICA
TICA_BASE_URL="https://portaltica.hacienda.go.cr/TicaExterno/"
TICA_QUERY_MAX_DAYS=15

# Navegador
TICA_BROWSER_HEADLESS=true
TICA_BROWSER_TIMEOUT_MS=30000
TICA_BROWSER_MAX_RETRIES=3
TICA_BROWSER_BACKOFF_SECONDS=1.0

# Sesiones terrestres con CAPTCHA manual
TICA_TERRESTRIAL_SESSION_TTL_SECONDS=180
TICA_TERRESTRIAL_PROCESSING_TIMEOUT_SECONDS=180
TICA_TERRESTRIAL_MAX_SESSIONS=3

# Cache
TICA_CACHE_TTL_SECONDS=3600
TICA_CEDULA_JURIDICA_MARITIMA=095144
